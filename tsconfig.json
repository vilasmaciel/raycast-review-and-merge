{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["src/**/*", "tests/**/*", "raycast-env.d.ts"],
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "target": "ES2022",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  }
}
